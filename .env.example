# Frontend (Vite). Copy to .env.local and fill.
# App ID is public; use the one from Privy dashboard.
VITE_PRIVY_APP_ID=cmmjdzulz01do0cl887btsbq8

# Optional: API base URL for signer-context/sign. Leave empty for same-origin (e.g. Vercel).
# For local dev with `vercel dev`, leave empty so requests go to same host.
# VITE_API_BASE=

# --- Server-only (Vercel / API). Do NOT add VITE_ prefix. Never commit secrets. ---
# PRIVY_APP_ID=cmmjdzulz01do0cl887btsbq8
# PRIVY_APP_SECRET=your_app_secret_from_privy_dashboard

# Optional: when API runs on another host (e.g. local API on :3000), set so signer-context returns correct serverUrl.
# API_BASE_URL=http://localhost:3000
